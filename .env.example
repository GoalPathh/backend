PORT=4000
FRONTEND_URL=http://localhost:3000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_URL or PUBLIC_URL are also accepted as aliases.
SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is also accepted as an alias.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Development only. Must reference an existing auth.users UUID.
DEFAULT_USER_ID=
# Enable or disable Google OAuth in Supabase Auth (true/false).
SUPABASE_GOOGLE_OAUTH_ENABLED=true

# ── AI Provider Configuration ────────────────────────────────────────────────
# Choose your driver:  "raw" (default)  or  "vercel"
#
#  "raw"    → custom Node fetch + SSE parser (llm-client.ts).
#              Best for local LMStudio / Ollama / TokenRouter / Gemini proxies
#              that emit partial / non-standard chunks.
#  "vercel" → AI SDK (@ai-sdk/openai + ai@6) with text-only chat.
#              Best for hosted OpenAI / together.ai / groq / vLLM proxies
#              that emit strict OpenAI-compatible JSON or SSE.
LLM_DRIVER=raw

# Common LLM_PROVIDER_URL presets:
#   Gemini official:          https://generativelanguage.googleapis.com/v1beta/openai
#   Local LMStudio:           http://127.0.0.1:1234/v1
#   Local Ollama (compat):    http://127.0.0.1:11434/v1
#   Local TokenRouter/Gemini: http://localhost:20128/v1
#   OpenAI hosted:            https://api.openai.com/v1
#   Together.ai:              https://api.together.xyz/v1
#   Groq:                     https://api.groq.com/openai/v1
LLM_PROVIDER_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=YOUR_GEMINI_API_KEY
# LLM_MODEL examples:
#   Local:   "local-model"  (whatever your server loads)
#   OpenAI:  "gpt-4o-mini"
#   Gemini: "gemini-3.1-flash-lite"
LLM_MODEL=gemini-3.1-flash-lite

# Cloudinary signed uploads for profile avatars
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=goalpath/avatars
